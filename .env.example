# =============================================================================
# Contoso Financial — Environment Variables Reference
# Copy this file to .env and fill in real values before running locally.
# In AWS, these are stored in SSM Parameter Store (SecureString) or
# AWS Secrets Manager and injected into ECS task definitions at runtime.
# NEVER commit a populated .env file to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# Local: points to the postgres container (rds-postgres)
# AWS:   points to the RDS endpoint injected via SSM at task startup
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://contoso:contoso_secret@localhost:5432/contoso

# -----------------------------------------------------------------------------
# Redis / ElastiCache
# Local: points to the redis container (elasticache-redis)
# AWS:   ElastiCache primary endpoint (no auth token required for t3.micro
#        in a private subnet; add ?ssl_cert_reqs=none for TLS clusters)
# Format: redis://<host>:<port>/<db_index>
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# MinIO / Amazon S3 object storage
# Local: MinIO container endpoint and credentials
# AWS:   MINIO_ENDPOINT is not used; boto3 uses the default AWS credential
#        chain (ECS task role IAM permissions). Set MINIO_ENDPOINT to empty
#        string in AWS environments.
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# -----------------------------------------------------------------------------
# S3 Bucket Names
# These bucket names must match the buckets created by Terraform (prod) or
# minio-init container (local). Do not include the s3:// prefix.
# -----------------------------------------------------------------------------
INPUT_BUCKET=reconciliation-input
OUTPUT_BUCKET=reconciliation-output

# -----------------------------------------------------------------------------
# Flask Web Application
# SECRET_KEY: used for signing session cookies. Must be a long random string.
#   Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# FLASK_ENV: set to "production" in AWS (disables debugger, enables error logging)
# -----------------------------------------------------------------------------
FLASK_SECRET_KEY=replace-me-with-a-random-64-char-hex-string
FLASK_ENV=development

# -----------------------------------------------------------------------------
# Batch Reconciliation Worker
# POLL_INTERVAL: seconds between MinIO polling cycles (local only).
#   In AWS, the container is woken by SQS messages from S3 Event Notifications
#   so this value is only used as a fallback safety poll.
# -----------------------------------------------------------------------------
POLL_INTERVAL=30

# -----------------------------------------------------------------------------
# Logging
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# In AWS, logs go to CloudWatch Logs via the awslogs driver; structured JSON
# logging is recommended (set LOG_FORMAT=json in prod).
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# AWS — production only (not used locally)
# AWS_REGION: the primary deployment region
# AWS_ACCOUNT_ID: used when constructing ECR image URIs in CI/CD
# AWS_PROFILE: optional, for developers using named CLI profiles locally
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
# AWS_PROFILE=contoso-prod   # uncomment for local AWS CLI access

# -----------------------------------------------------------------------------
# Terraform / Infrastructure
# These are not consumed by the application but referenced by CI/CD pipelines
# that run terraform apply.
# TF_STATE_BUCKET: the S3 bucket holding Terraform remote state
# TF_STATE_KEY:    path within the bucket for this project's state file
# TF_LOCK_TABLE:   DynamoDB table used for state locking
# -----------------------------------------------------------------------------
TF_STATE_BUCKET=contoso-terraform-state-us-east-1
TF_STATE_KEY=contoso-cloud-migration/prod/terraform.tfstate
TF_LOCK_TABLE=contoso-terraform-locks
